# saas-sec-agents — Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# Salesforce credentials (simple-salesforce / SOAP login)
# NOTE: SF_SECURITY_TOKEN is the token appended to your password for IP-unrestricted logins.
#       If your org uses a trusted IP range that includes your machine, SF_SECURITY_TOKEN can be empty.
#       For sandbox orgs, SF_DOMAIN should be set to "test".
#
SF_USERNAME=your.name@yourorg.com
SF_PASSWORD=YourSalesforcePassword
SF_SECURITY_TOKEN=YourSecurityToken
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_DOMAIN=login
# SF_DOMAIN=test   # Uncomment for sandbox orgs

# Anthropic API key (for agent harness)
ANTHROPIC_API_KEY=sk-ant-...

# CodeRabbit API key (Pro subscription)
# Used for on-demand reviews via CLI and CI pipeline triggers.
# Also add this as a GitHub Actions secret named CODERABBIT_API_KEY.
CODERABBIT_API_KEY=cr-...

# Optional: override default org alias for sfdc-connect
SFDC_ORG_ALIAS=default

# Qdrant session memory backend
# QDRANT_IN_MEMORY=1 (default) — no Docker needed; uses in-process Qdrant store.
# Set to 0 and configure QDRANT_HOST/PORT only if you want persistent cross-session memory.
QDRANT_IN_MEMORY=1
# QDRANT_HOST=localhost   # uncomment if running a Qdrant container
# QDRANT_PORT=6333        # uncomment if running a Qdrant container
