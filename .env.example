# saas-sec-agents — Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# Salesforce credentials (simple-salesforce / SOAP login)
# NOTE: SF_SECURITY_TOKEN is the token appended to your password for IP-unrestricted logins.
#       If your org uses a trusted IP range that includes your machine, SF_SECURITY_TOKEN can be empty.
#       For sandbox orgs, SF_DOMAIN should be set to "test".
#
SF_USERNAME=your.name@yourorg.com
SF_PASSWORD=YourSalesforcePassword
SF_SECURITY_TOKEN=YourSecurityToken
SF_INSTANCE_URL=https://yourorg--sandbox.sandbox.my.salesforce.com
SF_DOMAIN=test       # "test" for sandbox (recommended starting point); use "login" for production

# OpenAI API key (for agent harness — orchestrator, assessor, reporter)
OPENAI_API_KEY=sk-...

# Optional model overrides (defaults: gpt-5.3-chat-latest)
# When GPT-5.4 ships to the API, uncomment and update these three lines:
# LLM_MODEL_ORCHESTRATOR=gpt-5.4
# LLM_MODEL_ANALYST=gpt-5.4
# LLM_MODEL_REPORTER=gpt-5.4

# Azure OpenAI (FedRAMP High / IL5) — set these instead of OPENAI_API_KEY:
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01

# CodeRabbit API key (Pro subscription)
# Used for on-demand reviews via CLI and CI pipeline triggers.
# Also add this as a GitHub Actions secret named CODERABBIT_API_KEY.
CODERABBIT_API_KEY=cr-...

# ── Workday connector (Phase E) ────────────────────────────────────────────────
# Required for workday-connect collect/auth commands
WD_TENANT=acme_dpt1
WD_CLIENT_ID=your-workday-oauth-client-id
WD_CLIENT_SECRET=your-workday-oauth-client-secret
# Optional — defaults to https://{WD_TENANT}.workday.com/ccx/oauth2/{WD_TENANT}/token
# WD_TOKEN_URL=https://acme_dpt1.workday.com/ccx/oauth2/acme_dpt1/token
# WD_BASE_URL=http://localhost:8080  # point at WireMock for dev without a real tenant
WD_API_VERSION=v40.0
WD_ORG_ALIAS=acme-workday
WD_ASSESSMENT_OWNER=Security Team

# ── Org identity (used as --org default and in output filenames) ──────────────
# SFDC_ORG_ALIAS is the short label for the org — used in output folder and file naming.
# Example: "acme-sandbox" produces acme-sandbox_security_assessment.pdf
SFDC_ORG_ALIAS=my-org-sandbox

# Default environment: dev | test | prod
SFDC_ENV=dev

# ── Report branding (optional, customize for your company) ───────────────────
# Display name shown in report titles (e.g. "Acme Corp Salesforce Sandbox")
REPORT_ORG_DISPLAY_NAME=My Org Salesforce Sandbox

# Title prefix for the governance (PDF/DOCX) report
# Default if not set: "Salesforce Security Governance Assessment"
REPORT_GOVERNANCE_TITLE=Salesforce Security Governance Assessment

# Qdrant session memory backend
# QDRANT_IN_MEMORY=1 (default) — no Docker needed; uses in-process Qdrant store.
# Set to 0 and configure QDRANT_HOST/PORT only if you want persistent cross-session memory.
QDRANT_IN_MEMORY=1
# QDRANT_HOST=localhost   # uncomment if running a Qdrant container
# QDRANT_PORT=6333        # uncomment if running a Qdrant container

# ── OpenSearch (Phase H — continuous monitoring) ─────────────────────────────
# When running via Docker Compose the URL is pre-set to http://opensearch:9200.
# For local development (no Docker) point at localhost.
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_EXPORT_ON_RUN=1       # uncomment to auto-export after every agent-loop run

# ── JWT Bearer Flow (preferred for production / CI/CD) ────────────────────────
# Requires a Salesforce Connected App with "Use digital signatures" enabled.
# Private key MUST be stored outside the repo directory (chmod 600).
#
# SF_AUTH_METHOD=jwt               # uncomment to switch from SOAP to JWT
# SF_CONSUMER_KEY=3MVG9...         # Connected App Consumer Key (Client ID)
# SF_PRIVATE_KEY_PATH=/Users/you/salesforce_jwt_private.pem
#
# Generate keypair:
#   openssl genrsa -out ~/salesforce_jwt_private.pem 2048
#   openssl req -new -x509 -key ~/salesforce_jwt_private.pem -out ~/salesforce_cert.crt -days 365
# Upload salesforce_cert.crt to Connected App → "Use digital signatures".
