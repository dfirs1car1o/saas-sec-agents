                {
                  "id": "sscf-ipy-005_sfdc_note",
                  "name": "platform-note",
                  "prose": "Salesforce-specific: Data residency is configured via Salesforce Government Cloud (FedRAMP) or Hyperforce region selection. Standard Salesforce orgs default to US multi-tenant infrastructure. Confirm Hyperforce region or Government Cloud tier if regulated data residency is required."
                }
              ]
            }
          ]
        },
        {
          "control-id": "sscf-con-003",
          "adds": [
            {
              "position": "ending",
              "parts": [
                {
                  "id": "sscf-con-003_sfdc_note",
                  "name": "platform-note",
                  "prose": "Salesforce-specific: Connected App OAuth credentials must be stored in Salesforce Secrets Manager or org-level Named Credentials. JWT Bearer Flow is the preferred authentication for server-to-server integrations. Security Tokens are considered legacy and should be replaced with JWT where possible."
                }
              ]
            }
          ]
        },
        {
          "control-id": "sscf-log-001",
          "adds": [
            {
              "position": "ending",
              "parts": [
                {
                  "id": "sscf-log-001_sfdc_note",
                  "name": "platform-note",
                  "prose": "Salesforce-specific: Event Monitoring (Shield or add-on) is required for full API event, report export, and login history. Event Log Files must be forwarded to SIEM. Platform Events and Change Data Capture should also be captured for real-time detection."
                }
              ]
            }
          ]
        }
